          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ERC-20 和 TRC-20 代币的小数位由合约提供，Solana 代币的小数位则存储在 mint 账户中。请将已跟踪代币的小数位支持与原生资产显示精度分开管理。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
