        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当大量持币者通过去中心化验证者进行质押时，共识会更抗审查、分布更广，也更能抵御单点故障。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
