    "This is the default in Send. You can still override fee priority per transaction." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is the default in Send. You can still override fee priority per transaction."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这是发送页面中的默认值。你仍然可以按交易单独覆盖费用优先级。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這是發送頁面中的默認值。你仍然可以按交易單獨覆蓋費用優先級。"
          }
        }
      }
    },
    "This opens the Send composer with the same nonce and higher fee defaults so you can safely speed up or cancel the pending transaction." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This opens the Send composer with the same nonce and higher fee defaults so you can safely speed up or cancel the pending transaction."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这会打开发送编辑器，并使用相同 nonce 和更高默认手续费，方便你安全地加速或取消这笔待处理交易。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這會打開發送編輯器，並使用相同 nonce 和更高默認手續費，方便你安全地加速或取消這筆待處理交易。"
          }
        }
      }
    },
