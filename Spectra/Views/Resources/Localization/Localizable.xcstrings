    "Save Recipient To Address Book" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Save Recipient To Address Book"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将收款方保存到地址簿"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將收款方保存到地址簿"
          }
        }
      }
    },
    "Save trusted recipient addresses here so you can reuse them in Send without retyping. Spectra currently supports address book validation for Bitcoin, Litecoin, Dogecoin, Ethereum, Ethereum Classic, Arbitrum, Optimism, BNB Chain, Avalanche, Hyperliquid, Tron, Solana, Cardano, XRP Ledger, Monero, Sui, Aptos, TON, Internet Computer, NEAR, Polkadot, and Stellar." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Save trusted recipient addresses here so you can reuse them in Send without retyping. Spectra currently supports address book validation for Bitcoin, Litecoin, Dogecoin, Ethereum, Ethereum Classic, Arbitrum, Optimism, BNB Chain, Avalanche, Hyperliquid, Tron, Solana, Cardano, XRP Ledger, Monero, Sui, Aptos, TON, Internet Computer, NEAR, Polkadot, and Stellar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在这里保存可信收款地址，以便在发送时复用而无需重新输入。Spectra 当前支持 Bitcoin、Litecoin、Dogecoin、Ethereum、Ethereum Classic、Arbitrum、Optimism、BNB Chain、Avalanche、Hyperliquid、Tron、Solana、Cardano、XRP Ledger、Monero、Sui、Aptos、TON、Internet Computer、NEAR、Polkadot 和 Stellar 的地址簿校验。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在這裡保存可信收款地址，以便在發送時復用而無需重新輸入。Spectra 當前支持 Bitcoin、Litecoin、Dogecoin、Ethereum、Ethereum Classic、Arbitrum、Optimism、BNB Chain、Avalanche、Hyperliquid、Tron、Solana、Cardano、XRP Ledger、Monero、Sui、Aptos、TON、Internet Computer、NEAR、Polkadot 和 Stellar 的地址簿校驗。"
          }
        }
      }
    },
