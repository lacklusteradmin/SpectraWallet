    "You can keep rules configured even when alerts are disabled. Re-enable this later to resume notifications." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can keep rules configured even when alerts are disabled. Re-enable this later to resume notifications."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "即使提醒被禁用，你仍然可以保留规则配置。以后重新启用即可恢复通知。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "即使提醒被禁用，你仍然可以保留規則配置。以後重新啓用即可恢復通知。"
          }
        }
      }
    },
